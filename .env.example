# App runtime
APP_ENV=dev
BASE_URL=/erebus-web/public
FEATURE_PHASE2B_READONLY=1
FEATURE_PHASE3_OPS=0

# Primary catalog. These canonical names are shared with the Erebus Engine CLI.
EREBUS_DB_HOST=127.0.0.1
EREBUS_DB_PORT=3306
EREBUS_DB_NAME=erebus_threat_intel_prod
EREBUS_DB_USER=erebus_web
EREBUS_DB_PASSWORD=change-me
EREBUS_DB_SOCKET=

# Optional split Permission Intel catalog
EREBUS_PERMISSION_INTEL_DB_NAME=android_permission_intel

# Optional Python Erebus engine read API (pipeline status proxy).
# Start with: python -m erebus api serve
EREBUS_ENGINE_API_URL=http://127.0.0.1:45342

# Shared transient cache (php-fpm uses PrivateTmp, so do not rely on /tmp).
# Default: <app>/storage/cache (must be writable by the web user; on Fedora
# SELinux hosts use httpd_sys_rw_content_t).
# APP_CACHE_DIR=/var/www/html/erebus-web/storage/cache

# Optional build/diagnostics metadata
# APP_GIT_SHA=
